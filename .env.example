# Path to the SQLite database file
DATABASE_PATH=./data/akaun.db

# Path to the file storage root directory
STORAGE_PATH=./data/storage

# Bearer token for iOS Shortcuts / API access
API_BEARER_TOKEN=change-me

# Initial password for the auto-created `admin` account on first boot.
# If left unset, a strong random password is generated and printed to the logs once.
ADMIN_PASSWORD=

# Log level (trace|debug|info|warn|error). Defaults to debug in dev, info in prod.
# Note: the OpenRouter API key is redacted in logs at all levels.
LOG_LEVEL=info
