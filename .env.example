# Path to the SQLite database file
DATABASE_PATH=./data/akaun.db

# Path to the file storage root directory
STORAGE_PATH=./data/storage

# Max request body size accepted by the server (e.g. file uploads/scans).
# Must stay >= the app's own upload cap (MAX_UPLOAD_BYTES in
# src/lib/server/file-storage.ts, currently 15 MB) or uploads will be rejected
# here before the app's own size check ever runs, e.g.:
#   "Content-length of <n> exceeds limit of <BODY_SIZE_LIMIT> bytes"
BODY_SIZE_LIMIT=15M

# Initial password for the auto-created `admin` account on first boot.
# If left unset, a strong random password is generated and printed to the logs once.
ADMIN_PASSWORD=

# Log level (trace|debug|info|warn|error). Defaults to debug in dev, info in prod.
# Note: the OpenRouter API key is redacted in logs at all levels.
LOG_LEVEL=info

# Optional: serve over HTTPS instead of HTTP (applies to `bun run dev`/`preview`
# and the production server). Defaults to HTTP when unset.
# In dev, SSL_KEY_PATH/SSL_CERT_PATH can be left blank — a self-signed cert is
# generated automatically (browser will warn it's untrusted). The production
# server requires both paths to be set when SSL_ENABLED=true.
SSL_ENABLED=false
SSL_KEY_PATH=
SSL_CERT_PATH=
